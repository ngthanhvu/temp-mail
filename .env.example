# ============================
# Docker Compose (.env)
# Place in project root, docker-compose reads this automatically
# ============================
WEBHOOK_SECRET=change-me-to-a-strong-random-string
FRONTEND_URL=http://localhost:3000
NUXT_PUBLIC_API_BASE=http://localhost:4000

# ============================
# Backend (.env) — for dev without Docker
# Copy to backend/.env
# ============================
PORT=4000

# ============================
# Frontend (.env) — for dev without Docker
# Copy to frontend/.env
# ============================

# ============================
# Worker (wrangler.toml vars)
# Update worker/wrangler.toml
# ============================
# WEBHOOK_URL = "https://your-server.com/api/webhook/email"
# WEBHOOK_SECRET = "same-as-WEBHOOK_SECRET-above"
